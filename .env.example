# ─── BANCO DE DADOS (Neon PostgreSQL) ────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ─── NEXTAUTH ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="seu-secret-aqui"
NEXTAUTH_URL="https://seu-dominio.vercel.app"

# ─── APP ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"
NEXT_PUBLIC_APP_NAME="ConstruTech Pro"

# ─── STRIPE ──────────────────────────────────────────────────────────────────
# 1. Crie uma conta em https://stripe.com
# 2. Acesse Developers → API keys para obter as chaves
# 3. Execute: npx tsx scripts/create-stripe-products.ts  (gera os Price IDs abaixo)
# 4. Configure o webhook em: Developers → Webhooks → Add endpoint
#    URL: https://seu-dominio.vercel.app/api/stripe/webhook
#    Eventos: checkout.session.completed, customer.subscription.updated,
#             customer.subscription.deleted, invoice.payment_failed
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."    # Gerado pelo script create-stripe-products
STRIPE_PRICE_PRO="price_..."        # Gerado pelo script create-stripe-products

# ─── RESEND (e-mail transacional) ────────────────────────────────────────────
# 1. Crie conta em https://resend.com
# 2. Crie uma API Key em Settings → API Keys
# 3. Adicione e verifique seu domínio em Domains (ex: construtech.pro)
# 4. Configure EMAIL_FROM com o domínio verificado
RESEND_API_KEY="re_..."
EMAIL_FROM="ConstruTech Pro <noreply@construtech.pro>"

# ─── ANTHROPIC (opcional — análise IA de editais) ────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ─── CRON JOB (Vercel Cron + chamadas manuais) ───────────────────────────────
# Protege os endpoints /api/cron/* de acessos não autorizados
# Gere com: openssl rand -base64 32
CRON_SECRET="gere-com-openssl-rand-base64-32"

# ─── AWS S3 / CLOUDFLARE R2 (upload de arquivos no CDE) ──────────────────────
# Opção A — AWS S3
AWS_REGION="sa-east-1"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="construtech-uploads"

# Opção B — Cloudflare R2 (compatible with S3 SDK, sem egress fee)
# AWS_REGION="auto"
# AWS_ACCESS_KEY_ID="<R2 Access Key ID>"
# AWS_SECRET_ACCESS_KEY="<R2 Secret Access Key>"
# AWS_S3_BUCKET="construtech-uploads"
# AWS_S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# NEXT_PUBLIC_CDN_URL="https://cdn.construtech.pro"   # R2 custom domain (opcional)
