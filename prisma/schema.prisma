generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                   String             @id @default(cuid())
  name                 String
  cnpj                 String             @unique
  address              String?
  phone                String?
  email                String?
  logo                 String?
  segments             String[]
  stripeCustomerId     String?            @unique
  stripePriceId        String?
  stripeSubscriptionId String?
  plan                 Plan               @default(FREE)
  planExpiresAt        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  basesPreco           BasePreco[]
  cdeFolders           CdeFolder[]
  compras              Compra[]
  contatos             Contact[]
  diarios              DiarioObra[]
  documentos           Document[]
  licitacoes           Licitacao[]
  medicoes             Medicao[]
  orcamentos           Orcamento[]
  orgaos               Organization[]
  planejamentoTasks    PlanejamentoTask[]
  rpaJobs              RpaJob[]
  users                User[]
}

model User {
  id                 String                @id @default(cuid())
  name               String
  email              String                @unique
  passwordHash       String
  role               Role                  @default(ANALYST)
  avatar             String?
  emailNotifications Boolean               @default(true)
  companyId          String
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  emailVerified      DateTime?
  accounts           Account[]
  activities         Activity[]
  cdeFiles           CdeFile[]             @relation("CdeUploadedBy")
  diariosCreated     DiarioObra[]          @relation("DiarioCreatedBy")
  assignments        LicitacaoAssignment[]
  notifications      Notification[]
  sessions           Session[]
  company            Company               @relation(fields: [companyId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Licitacao {
  id               String                @id @default(cuid())
  number           String
  modality         Modality
  object           String
  fullObject       String?
  organ            String
  organId          String?
  status           LicitacaoStatus       @default(IDENTIFIED)
  estimatedValue   Decimal?              @db.Decimal(15, 2)
  proposedValue    Decimal?              @db.Decimal(15, 2)
  openingDate      DateTime?
  closingDate      DateTime?
  deliveryDate     DateTime?
  location         String?
  state            String?
  city             String?
  segment          String?
  judgmentCriteria String?
  portalUrl        String?
  editalUrl        String?
  editalFileKey    String?
  aiSummary        String?
  aiScore          Float?
  aiRequirements   Json?
  aiDocuments      Json?
  companyId        String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  activities       Activity[]
  company          Company               @relation(fields: [companyId], references: [id])
  organization     Organization?         @relation(fields: [organId], references: [id])
  assignments      LicitacaoAssignment[]
  documents        LicitacaoDocument[]
  orcamentos       Orcamento[]
  pipeline         PipelineEntry?

  @@index([status, companyId])
  @@index([closingDate])
}

model LicitacaoAssignment {
  id          String    @id @default(cuid())
  licitacaoId String
  userId      String
  role        String?
  assignedAt  DateTime  @default(now())
  licitacao   Licitacao @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@unique([licitacaoId, userId])
}

model Orcamento {
  id            String             @id @default(cuid())
  name          String
  version       Int                @default(1)
  status        OrcamentoStatus    @default(DRAFT)
  totalValue    Decimal            @default(0) @db.Decimal(15, 2)
  bdiPercentage Decimal            @default(25) @db.Decimal(5, 2)
  bdiConfig     Json?
  totalWithBdi  Decimal            @default(0) @db.Decimal(15, 2)
  licitacaoId   String?
  companyId     String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  compras       Compra[]
  diarios       DiarioObra[]
  medicoes      Medicao[]
  company       Company            @relation(fields: [companyId], references: [id])
  licitacao     Licitacao?         @relation(fields: [licitacaoId], references: [id])
  chapters      OrcamentoChapter[]
  tasks         PlanejamentoTask[]
}

model OrcamentoChapter {
  id          String          @id @default(cuid())
  code        String
  name        String
  order       Int
  orcamentoId String
  orcamento   Orcamento       @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  items       OrcamentoItem[]
}

model OrcamentoItem {
  id           String           @id @default(cuid())
  code         String
  description  String
  unit         String
  quantity     Decimal          @db.Decimal(15, 4)
  unitPrice    Decimal          @db.Decimal(15, 4)
  totalPrice   Decimal          @db.Decimal(15, 2)
  source       String?
  sourceCode   String?
  order        Int
  chapterId    String
  compositions Composition[]
  chapter      OrcamentoChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
}

model Composition {
  id          String             @id @default(cuid())
  code        String
  description String
  unit        String
  unitCost    Decimal            @db.Decimal(15, 4)
  source      String?
  itemId      String?
  item        OrcamentoItem?     @relation(fields: [itemId], references: [id])
  inputs      CompositionInput[]
}

model CompositionInput {
  id            String      @id @default(cuid())
  type          InputType
  code          String
  description   String
  unit          String
  coefficient   Decimal     @db.Decimal(15, 6)
  unitPrice     Decimal     @db.Decimal(15, 4)
  totalPrice    Decimal     @db.Decimal(15, 4)
  compositionId String
  composition   Composition @relation(fields: [compositionId], references: [id], onDelete: Cascade)
}

model Document {
  id             String              @id @default(cuid())
  name           String
  type           DocumentType
  category       String?
  fileKey        String
  fileSize       Int
  mimeType       String
  expirationDate DateTime?
  status         DocumentStatus      @default(VALID)
  ocrContent     String?
  companyId      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  company        Company             @relation(fields: [companyId], references: [id])
  licitacaoLinks LicitacaoDocument[]

  @@index([expirationDate, status])
}

model LicitacaoDocument {
  id           String         @id @default(cuid())
  licitacaoId  String
  documentId   String?
  requiredName String
  status       DocCheckStatus @default(PENDING)
  order        Int            @default(0)
  notes        String?
  document     Document?      @relation(fields: [documentId], references: [id])
  licitacao    Licitacao      @relation(fields: [licitacaoId], references: [id])
}

model Organization {
  id         String      @id @default(cuid())
  name       String
  cnpj       String?
  type       String?
  state      String?
  city       String?
  portalUrl  String?
  companyId  String
  contacts   Contact[]
  licitacoes Licitacao[]
  company    Company     @relation(fields: [companyId], references: [id])
}

model Contact {
  id             String        @id @default(cuid())
  name           String
  email          String?
  phone          String?
  role           String?
  organizationId String?
  companyId      String
  activities     Activity[]
  company        Company       @relation(fields: [companyId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model PipelineEntry {
  id          String        @id @default(cuid())
  stage       PipelineStage
  value       Decimal?      @db.Decimal(15, 2)
  probability Int?
  licitacaoId String        @unique
  updatedAt   DateTime      @updatedAt
  licitacao   Licitacao     @relation(fields: [licitacaoId], references: [id])
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean      @default(false)
  userId      String
  licitacaoId String?
  contactId   String?
  createdAt   DateTime     @default(now())
  contact     Contact?     @relation(fields: [contactId], references: [id])
  licitacao   Licitacao?   @relation(fields: [licitacaoId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
}

model RpaJob {
  id            String     @id @default(cuid())
  name          String
  type          RpaJobType
  config        Json
  schedule      String?
  lastRunAt     DateTime?
  lastRunStatus String?
  isActive      Boolean    @default(true)
  companyId     String
  createdAt     DateTime   @default(now())
  company       Company    @relation(fields: [companyId], references: [id])
  logs          RpaLog[]
}

model RpaLog {
  id         String   @id @default(cuid())
  jobId      String
  status     String
  message    String?
  details    Json?
  itemsFound Int      @default(0)
  duration   Int?
  createdAt  DateTime @default(now())
  job        RpaJob   @relation(fields: [jobId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Medicao {
  id          String        @id @default(cuid())
  number      Int
  name        String
  description String?
  orcamentoId String
  companyId   String
  startDate   DateTime
  endDate     DateTime
  status      MedicaoStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id])
  orcamento   Orcamento     @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  items       MedicaoItem[]

  @@index([companyId])
  @@index([orcamentoId])
}

model MedicaoItem {
  id               String  @id @default(cuid())
  medicaoId        String
  orcamentoItemId  String
  description      String
  unit             String
  quantityBudget   Decimal @db.Decimal(15, 4)
  quantityPrev     Decimal @default(0) @db.Decimal(15, 4)
  quantityMeasured Decimal @default(0) @db.Decimal(15, 4)
  unitPrice        Decimal @db.Decimal(15, 4)
  notes            String?
  medicao          Medicao @relation(fields: [medicaoId], references: [id], onDelete: Cascade)
}

model PlanejamentoTask {
  id          String     @id @default(cuid())
  name        String
  code        String?
  orcamentoId String?
  companyId   String
  startDate   DateTime
  endDate     DateTime
  progress    Int        @default(0)
  laborCount  Int?
  notes       String?
  dependsOn   String[]
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  company     Company    @relation(fields: [companyId], references: [id])
  orcamento   Orcamento? @relation(fields: [orcamentoId], references: [id])

  @@index([companyId])
  @@index([orcamentoId])
}

model DiarioObra {
  id          String        @id @default(cuid())
  companyId   String
  orcamentoId String?
  date        DateTime
  shift       DiarioShift   @default(MORNING)
  weather     DiarioWeather @default(SUNNY)
  laborCount  Int?
  description String
  occurrences String?
  materials   String?
  equipment   String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  company     Company       @relation(fields: [companyId], references: [id])
  createdBy   User          @relation("DiarioCreatedBy", fields: [createdById], references: [id])
  orcamento   Orcamento?    @relation(fields: [orcamentoId], references: [id])

  @@index([companyId])
  @@index([date])
}

model Compra {
  id          String       @id @default(cuid())
  number      Int
  name        String
  companyId   String
  orcamentoId String?
  status      CompraStatus @default(DRAFT)
  deadline    DateTime?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id])
  orcamento   Orcamento?   @relation(fields: [orcamentoId], references: [id])
  items       CompraItem[]
  cotacoes    Cotacao[]

  @@index([companyId])
}

model CompraItem {
  id             String   @id @default(cuid())
  compraId       String
  description    String
  unit           String
  quantity       Decimal  @db.Decimal(15, 4)
  estimatedPrice Decimal? @db.Decimal(15, 4)
  category       String?
  abcClass       String?
  notes          String?
  order          Int      @default(0)
  compra         Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
}

model Cotacao {
  id           String    @id @default(cuid())
  compraId     String
  supplier     String
  contactName  String?
  contactPhone String?
  totalValue   Decimal   @db.Decimal(15, 2)
  validUntil   DateTime?
  notes        String?
  selected     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  compra       Compra    @relation(fields: [compraId], references: [id], onDelete: Cascade)
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum Role {
  ADMIN
  MANAGER
  BUDGETEER
  ANALYST
}

enum LicitacaoStatus {
  IDENTIFIED
  ANALYZING
  GO
  NO_GO
  BUDGETING
  PROPOSAL_SENT
  WON
  LOST
  CANCELED
}

enum Modality {
  PREGAO_ELETRONICO
  PREGAO_PRESENCIAL
  CONCORRENCIA
  TOMADA_PRECOS
  CONVITE
  CONCURSO
  DIALOGO_COMPETITIVO
  RDC
}

enum OrcamentoStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  APPROVED
  SUBMITTED
}

enum InputType {
  MATERIAL
  LABOR
  EQUIPMENT
  OTHER
}

enum DocumentType {
  CERTIDAO_NEGATIVA
  ATESTADO_CAPACIDADE
  BALANCO_PATRIMONIAL
  CONTRATO_SOCIAL
  PROCURACAO
  ALVARA
  REGISTRO_CREA
  CERTIDAO_FGTS
  CERTIDAO_INSS
  CERTIDAO_TRABALHISTA
  CERTIDAO_FEDERAL
  CERTIDAO_ESTADUAL
  CERTIDAO_MUNICIPAL
  OUTROS
}

enum DocumentStatus {
  VALID
  EXPIRING
  EXPIRED
  PENDING
}

enum DocCheckStatus {
  PENDING
  UPLOADED
  APPROVED
  REJECTED
  NOT_APPLICABLE
}

enum PipelineStage {
  PROSPECTING
  ANALYSIS
  DECISION
  BUDGETING
  PROPOSAL
  RESULT
}

enum ActivityType {
  NOTE
  TASK
  CALL
  EMAIL
  MEETING
  DEADLINE
  STATUS_CHANGE
  DOCUMENT_UPLOAD
  SYSTEM
}

enum RpaJobType {
  EDITAL_SEARCH
  DOCUMENT_CHECK
  PRICE_UPDATE
}

enum MedicaoStatus {
  PENDING
  IN_PROGRESS
  SUBMITTED
  APPROVED
  PAID
}

enum DiarioShift {
  MORNING
  AFTERNOON
  NIGHT
  FULL_DAY
}

enum DiarioWeather {
  SUNNY
  CLOUDY
  RAINY
  STORM
  PARTIAL
}

enum CompraStatus {
  DRAFT
  QUOTING
  APPROVED
  ORDERED
  PARTIALLY_DELIVERED
  DELIVERED
  CANCELED
}

// ── CDE — Common Data Environment ────────────────────────────────────────────

model CdeFolder {
  id          String      @id @default(cuid())
  name        String
  description String?
  parentId    String?
  companyId   String
  color       String?     @default("#6366f1")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  company     Company     @relation(fields: [companyId], references: [id])
  parent      CdeFolder?  @relation("FolderChildren", fields: [parentId], references: [id])
  children    CdeFolder[] @relation("FolderChildren")
  files       CdeFile[]

  @@index([companyId])
  @@index([parentId])
}

model CdeFile {
  id           String    @id @default(cuid())
  name         String
  description  String?
  fileKey      String
  fileSize     Int
  mimeType     String
  version      Int       @default(1)
  folderId     String
  companyId    String
  uploadedById String
  tags         String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  folder       CdeFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploadedBy   User      @relation("CdeUploadedBy", fields: [uploadedById], references: [id])

  @@index([folderId])
  @@index([companyId])
}

// ── Bases Próprias de Preços ──────────────────────────────────────────────────

model BasePreco {
  id          String          @id @default(cuid())
  name        String
  description String?
  source      String          // SINAPI | ORSE | SEINFRA | SICRO | CUSTOM
  region      String?
  companyId   String
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  company     Company         @relation(fields: [companyId], references: [id])
  items       BasePrecoItem[]

  @@index([companyId])
}

model BasePrecoItem {
  id          String    @id @default(cuid())
  baseId      String
  code        String
  description String
  unit        String
  unitPrice   Decimal   @db.Decimal(15, 4)
  category    String?
  source      String?
  updatedAt   DateTime  @updatedAt
  base        BasePreco @relation(fields: [baseId], references: [id], onDelete: Cascade)

  @@index([baseId])
  @@index([baseId, code])
}
